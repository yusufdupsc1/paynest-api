# =============================================================================
# PayNest — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in real values before running locally.
#
#   cp .env.examples .env
#
# Render deploys read these variables from the dashboard (Settings → Environment)
# or from render.yaml.  See DEPLOYMENT.md for step-by-step instructions.
# =============================================================================


# =============================================================================
# 1. APPLICATION
# =============================================================================

# "development" enables TypeORM synchronize + verbose logging.
# "production" disables synchronize and tightens error responses.
NODE_ENV=production

# Port the NestJS HTTP server listens on.  Render sets this automatically.
PORT=3000

# Public URL of the deployed service.  Used for callback/return URLs and CORS.
# On Render: https://your-service.onrender.com
APP_URL=https://your-service.onrender.com

# Comma-separated origins allowed by CORS.  Must match APP_URL in production.
APP_ORIGIN=https://your-service.onrender.com


# =============================================================================
# 2. DATABASE  (Supabase PostgreSQL)
# =============================================================================

# Direct Postgres connection parameters from the Supabase dashboard.
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password

# Set to "false" in production once migrations are applied.
# The app will refuse to boot in production if this is "true".
DB_SYNCHRONIZE=false


# =============================================================================
# 3. REDIS  (Upstash)
# =============================================================================

# Option A — individual fields (Render / Upstash free tier):
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password

# Option B — full URL (takes precedence when present):
# REDIS_URL=rediss://default:password@host.upstash.io:6379

# Enable TLS for Upstash / any remote Redis.
REDIS_TLS=true


# =============================================================================
# 4. AUTHENTICATION
# =============================================================================

# Secret used to sign and verify JWT tokens.  MUST be changed for production.
JWT_SECRET=change-me-to-a-random-64-char-string

# Token lifetime.  Supports "24h", "7d", 3600 (seconds), etc.
JWT_EXPIRES_IN=24h

# Demo credentials for the local login endpoint (POST /auth/login).
# In production, replace with a real user store or SSO integration.
ADMIN_PASSWORD=change-me-admin-password
OPERATOR_PASSWORD=change-me-operator-password
VIEWER_PASSWORD=change-me-viewer-password


# =============================================================================
# 5. PAYMENT GATEWAYS
# =============================================================================
# Only Stripe is required at boot.  Other gateways degrade gracefully until
# their routes are actually called.
# =============================================================================

# --- Stripe (required at boot) -----------------------------------------------
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# --- PayPal ------------------------------------------------------------------
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# --- bKash -------------------------------------------------------------------
BKASH_API_KEY=your-bkash-api-key
BKASH_API_SECRET=your-bkash-api-secret
BKASH_MERCHANT_ID=your-bkash-merchant-id
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password
BKASH_BASE_URL=https://checkout.sandbox.bka.sh/v1.2.0-beta

# --- Nagad -------------------------------------------------------------------
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_MERCHANT_KEY=your-nagad-merchant-key
NAGAD_USERNAME=your-nagad-username
NAGAD_PASSWORD=your-nagad-password
NAGAD_BASE_URL=https://sandbox.mynagad.com

# --- Razorpay ----------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RAZORPAY_BASE_URL=https://api.razorpay.com/v1

# --- SSLCommerz --------------------------------------------------------------
SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id
SSLCOMMERZ_STORE_PASSWORD=your-sslcommerz-store-password
SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com

# --- Aamarpay ----------------------------------------------------------------
AAMARPAY_STORE_ID=your-aamarpay-store-id
AAMARPAY_SIGNATURE_KEY=your-aamarpay-signature-key
AAMARPAY_BASE_URL=https://sandbox.aamarpay.com

# --- Paystack ----------------------------------------------------------------
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# --- Flutterwave -------------------------------------------------------------
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxx-X

# --- Mercado Pago ------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxx-xxxxxxxxxxxxxxxx-xxxxxxxxxxxx

# --- Square ------------------------------------------------------------------
SQUARE_ACCESS_TOKEN=sandbox-sq0atb-xxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=your-square-location-id

# --- Adyen -------------------------------------------------------------------
ADYEN_API_KEY=your-adyen-api-key
ADYEN_MERCHANT_ACCOUNT=your-adyen-merchant-account

# --- PhonePe -----------------------------------------------------------------
PHONEPE_MERCHANT_ID=your-phonepe-merchant-id
PHONEPE_SALT_KEY=your-phonepe-salt-key
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox


# =============================================================================
# 6. LOCAL DEVELOPMENT QUICKSTART
# =============================================================================
#
# Option A — Docker (recommended):
#
#   docker compose -f docker/docker-compose.yml up -d --build
#   open http://localhost:3000
#
# The docker-compose file injects DB_HOST=postgres and REDIS_HOST=redis
# automatically.  You only need .env for gateway secrets and JWT_SECRET.
#
# Option B — Bare metal:
#
#   1. Start Postgres and Redis locally.
#   2. cp .env.examples .env
#   3. Set DB_HOST=localhost  REDIS_HOST=localhost
#   4. bun install
#   5. bun run start:dev
#   6. open http://localhost:3000
#   7. Swagger UI: http://localhost:3000/docs
#
# Option C — Render free-tier demo:
#
#   See DEPLOYMENT.md for the full runbook.  In short:
#   1. Create a Supabase project → copy DB_* values here.
#   2. Create an Upstash Redis    → copy REDIS_* values here.
#   3. Push to GitHub → Render auto-deploys via render.yaml.
#   4. Set secrets in Render dashboard (not in this file).
#
# =============================================================================
