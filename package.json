{
  "name": "payment-dashboard",
  "version": "1.0.0",
  "description": "Unified payment dashboard with 15+ gateway support",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "build-check": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "lint-check": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "preflight:env": "node scripts/preflight-env.js",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --selectProjects unit",
    "test:integration": "jest --config jest.config.ts --selectProjects integration",
    "test:e2e": "jest --config jest.config.ts --selectProjects e2e",
    "test:regression": "jest --config jest.config.ts --selectProjects regression",
    "test:security-smoke": "jest --config jest.config.ts --selectProjects e2e --runTestsByPath test/e2e/security-smoke.e2e-spec.ts",
    "test:performance-smoke": "jest --config jest.config.ts --selectProjects regression --runTestsByPath test/regression/performance-smoke.spec.ts",
    "test:deploy-readiness": "npm run preflight:env && npm run -s type-check",
    "test:release-gate": "npm run lint-check && npm run type-check && npm run test:unit -- --runInBand && npm run test:integration -- --runInBand && npm run test:e2e -- --runInBand && npm run test:regression -- --runInBand && npm run test:performance-smoke -- --runInBand && npm run build-check",
    "test:cov": "jest --config jest.config.ts --coverage",
    "migration:generate": "typeorm migration:generate -d src/config/data-source.ts",
    "migration:run": "typeorm migration:run -d src/config/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@supabase/supabase-js": "^2.39.0",
    "bull": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "crypto-js": "^4.2.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.0",
    "nestjs-pino": "^4.6.1",
    "opossum": "^9.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "stripe": "^14.18.0",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bull": "^4.10.0",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/opossum": "^8.1.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
